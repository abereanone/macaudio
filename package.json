{
  "name": "macaudio",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev ./dist",
    "deploy": "astro build && wrangler pages deploy ./dist",
    "astro": "astro",
    "typecheck": "astro check",
    "db:migrate:local": "wrangler d1 migrations apply macaudio-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply macaudio-db --remote",
    "db:import:local": "wrangler d1 execute macaudio-db --local --file=./db/import.sql",
    "db:import:remote": "wrangler d1 execute macaudio-db --remote --file=./db/import.sql"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.2.1",
    "astro": "^5.2.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "typescript": "^5.7.3",
    "wrangler": "^4.102.0"
  }
}
