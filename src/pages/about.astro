---
import Base from "../layouts/Base.astro";
---
<Base title="About" description="About this audio archive.">
  <section class="section container" style="max-width:720px">
    <h1>About</h1>
    <p>This is an archive of preaching and teaching by Michael Coughlin — Sunday sermons, classes
      and Bible studies, conference messages, open-air evangelism, and the <em>Be A Berean</em>
      podcast.</p>
    <p>Every recording is transcribed and indexed by scripture, so you can search for a phrase,
      browse by passage, or follow a series. Audio can be streamed or downloaded.</p>
    <p class="muted">Spot an error in a transcript or want a recording removed? Reach out and it'll be fixed.</p>
  </section>
</Base>
